    private async Task UploadEventImage(Microsoft.AspNetCore.Components.Forms.InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        if (file.Size > 10 * 1024 * 1024)
        {
            Toast.Error("上传的图片不能超过 10MB");
            return;
        }

        _uploadingImage = true;
        StateHasChanged();

        try
        {
            using var stream = file.OpenReadStream(10 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var bytes = ms.ToArray();

            var (fileUrl, err) = await Api.UploadFileAsync(_selectedExhibition.Id, bytes, file.Name, file.ContentType);
            if (err != null)
            {
                Toast.Error(err);
            }
            else if (!string.IsNullOrWhiteSpace(fileUrl))
            {
                _editingEvent.ImageUrl = fileUrl;
                Toast.Success("图片上传成功");
            }
        }
        catch (Exception ex)
        {
            Toast.Error($"图片上传失败: {ex.Message}");
        }
        finally
        {
            _uploadingImage = false;
            StateHasChanged();
        }
    }

