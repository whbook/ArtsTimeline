@code {
    private SfGrid<ExhibitionListItem> _grid = null!;
    private List<ExhibitionListItem> _items = [];
    private bool _showDialog;
    private bool _isNew;
    private bool _syncing;
    private string? _syncHint;
    private ExhibitionModel _model = new();
    private bool _initialLoadDone;

    // 数据编辑器状态
    private bool _showDataManager;
    private ExhibitionListItem _selectedExhibition = new();
    private List<PeriodDto> _periods = [];
    private List<StreamDto> _streams = [];
    private List<TimelineEventDto> _events = [];

    // 分期/泳道/事件编辑窗体
    private bool _showPeriodEdit;
    private bool _isNewPeriod;
    private PeriodDto _editingPeriod = new();

    private bool _showStreamEdit;
    private bool _isNewStream;
    private StreamDto _editingStream = new();

    private bool _showEventEdit;
    private bool _isNewEvent;
    private TimelineEventDto _editingEvent = new();
    private bool _hasEventEndDate;

    // 预览窗体
    private bool _showPreviewDialog;
    private string _previewUrl = string.Empty;
    private string _previewType = "web"; // web | image

    // 事件分页与筛选
    private int _eventPage = 1;
    private int _eventPageSize = 25;
    private int _eventTotalCount;
    private int _eventTotalPages => (int)Math.Ceiling((double)_eventTotalCount / _eventPageSize);
    private string? _eventKeyword;
    private int? _eventImportance;

    private class ImportanceOption
    {
        public int? Value { get; set; }
        public string Label { get; set; } = string.Empty;
    }

    private readonly List<ImportanceOption> _importanceOptions = new()
    {
        new ImportanceOption { Value = null, Label = "全部重要度" },
        new ImportanceOption { Value = 1, Label = "1 - 最高" },
        new ImportanceOption { Value = 2, Label = "2 - 较高" },
        new ImportanceOption { Value = 3, Label = "3 - 普通" },
        new ImportanceOption { Value = 4, Label = "4 - 较低" },
        new ImportanceOption { Value = 5, Label = "5 - 最低" }
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _initialLoadDone) return;
        _initialLoadDone = true;
        await AuthService.InitializeAsync();
        await LoadAsync();
        StateHasChanged();
    }

    private async Task LoadAsync()
    {
        var (items, err) = await Api.GetExhibitionsWithErrorAsync();
        if (err is not null)
        {
            Toast.Error(err);
            _items = [];
            _syncHint = "加载展览列表失败，请确认已登录且 API 服务可用（http://localhost:5287）。";
            return;
        }

        _items = items ?? [];
        _syncHint = $"共 {_items.Count} 个展览主题（含前端 SPA 数据目录中的主题）。可编辑运行参数后保存。";
    }

    private async Task SyncFromData()
    {
        _syncing = true;
        var (ok, count, message, err) = await Api.SyncExhibitionsFromDataAsync();
        _syncing = false;
        if (ok)
        {
            Toast.Success(message ?? $"已同步 {count} 个展览");
            await LoadAsync();
        }
        else Toast.Error(err ?? "同步失败");
    }

    private async Task ImportLegacyData()
    {
        _syncing = true;
        var (ok, err, msg) = await Api.ImportLegacyJsonAsync();
        _syncing = false;
        if (ok)
        {
            Toast.Success(msg ?? "历史展览数据一键无损导入成功！");
            await LoadAsync();
        }
        else
        {
            Toast.Error(err ?? "导入失败");
        }
    }

    private void CreateNew()
    {
        _isNew = true;
        _model = new ExhibitionModel();
        _showDialog = true;
    }

    private async Task Edit(Guid id)
    {
        var ex = await Api.GetExhibitionAsync(id);
        if (ex is null) { Toast.Error("加载失败"); return; }
        _model = ex;
        _isNew = false;
        _showDialog = true;
    }

    private async Task Save()
    {
        var (ok, err) = await Api.SaveExhibitionAsync(_model, _isNew);
        if (ok) { Toast.Success("保存成功"); _showDialog = false; await LoadAsync(); }
        else Toast.Error(err ?? "保存失败");
    }

    private Task Cancel() { _showDialog = false; return Task.CompletedTask; }

    #region 子数据管理器逻辑

    private async Task OpenDataManager(ExhibitionListItem ex)
    {
        _selectedExhibition = ex;
        _eventPage = 1;
        _eventKeyword = null;
        _eventImportance = null;

        // 加载当前展览关联的 Periods, Streams, Events
        await LoadPeriodsAsync();
        await LoadStreamsAsync();
        await LoadEventsAsync();

        _showDataManager = true;
    }

    private async Task LoadPeriodsAsync()
    {
        _periods = await Api.GetPeriodsAsync(_selectedExhibition.Id) ?? [];
    }

    private async Task LoadStreamsAsync()
    {
        _streams = await Api.GetStreamsAsync(_selectedExhibition.Id) ?? [];
    }

    private async Task LoadEventsAsync()
    {
        var pageResult = await Api.GetEventsAsync(_selectedExhibition.Id, _eventPage, _eventPageSize, _eventKeyword, _eventImportance);
        if (pageResult is not null)
        {
            _events = pageResult.Items;
            _eventTotalCount = pageResult.TotalCount;
        }
        else
        {
            _events = [];
            _eventTotalCount = 0;
        }
    }

    private string FormatFuzzyDateString(FuzzyDateDto fd)
    {
        if (fd is null) return string.Empty;
        var yStr = fd.Year < 0 ? $"公元前 {Math.Abs(fd.Year)}" : $"{fd.Year}";
        var suf = fd.Accuracy switch
        {
            "approximate" => " 约",
            "not_before" => " 不早于",
            "not_after" => " 不晚于",
            "either_or" => fd.OrYear.HasValue ? $" 或 {(fd.OrYear.Value < 0 ? $"公元前 {Math.Abs(fd.OrYear.Value)}" : $"{fd.OrYear.Value}")}" : "",
            _ => ""
        };
        return $"{yStr}{suf}年";
    }

    #endregion

    #region Periods CRUD

    private void CreatePeriod()
    {
        _isNewPeriod = true;
        _editingPeriod = new PeriodDto
        {
            ExhibitionId = _selectedExhibition.Id,
            ColorHex = "#111827",
            ColorBackground = "#f3f4f6",
            Start = new FuzzyDateDto { Year = 1900 },
            End = new FuzzyDateDto { Year = 2000 }
        };
        _showPeriodEdit = true;
    }

    private void EditPeriod(PeriodDto p)
    {
        _isNewPeriod = false;
        _editingPeriod = p;
        _showPeriodEdit = true;
    }

    private async Task SavePeriodAsync()
    {
        if (string.IsNullOrWhiteSpace(_editingPeriod.Id)) { Toast.Error("分期 ID 不能为空"); return; }
        var (ok, err) = await Api.SavePeriodAsync(_editingPeriod, _isNewPeriod);
        if (ok)
        {
            Toast.Success("保存成功");
            _showPeriodEdit = false;
            await LoadPeriodsAsync();
        }
        else Toast.Error(err ?? "保存失败");
    }

    private async Task DeletePeriod(PeriodDto p)
    {
        var (ok, err) = await Api.DeletePeriodAsync(_selectedExhibition.Id, p.Id);
        if (ok)
        {
            Toast.Success("删除成功");
            await LoadPeriodsAsync();
        }
        else Toast.Error(err ?? "删除失败");
    }

    #endregion

    #region Streams CRUD

    private void CreateStream()
    {
        _isNewStream = true;
        _editingStream = new StreamDto
        {
            ExhibitionId = _selectedExhibition.Id,
            Color = "#2563eb",
            Start = new FuzzyDateDto { Year = 1900 },
            End = new FuzzyDateDto { Year = 2000 }
        };
        _showStreamEdit = true;
    }

    private void EditStream(StreamDto s)
    {
        _isNewStream = false;
        _editingStream = s;
        _showStreamEdit = true;
    }

    private async Task SaveStreamAsync()
    {
        if (string.IsNullOrWhiteSpace(_editingStream.Id)) { Toast.Error("泳道 ID 不能为空"); return; }
        var (ok, err) = await Api.SaveStreamAsync(_editingStream, _isNewStream);
        if (ok)
        {
            Toast.Success("保存成功");
            _showStreamEdit = false;
            await LoadStreamsAsync();
        }
        else Toast.Error(err ?? "保存失败");
    }

    private async Task DeleteStream(StreamDto s)
    {
        var (ok, err) = await Api.DeleteStreamAsync(_selectedExhibition.Id, s.Id);
        if (ok)
        {
            Toast.Success("删除成功");
            await LoadStreamsAsync();
        }
        else Toast.Error(err ?? "删除失败");
    }

    #endregion

    #region Events CRUD

    private void CreateEvent()
    {
        _isNewEvent = true;
        _editingEvent = new TimelineEventDto
        {
            ExhibitionId = _selectedExhibition.Id,
            Importance = 3,
            Date = new FuzzyDateDto { Year = 1900 },
            Tags = [],
            MetaJson = "{}"
        };
        _hasEventEndDate = false;
        _showEventEdit = true;
    }

    private void EditEvent(TimelineEventDto ev)
    {
        _isNewEvent = false;
        _editingEvent = ev;
        _hasEventEndDate = ev.EndDate is not null;
        _showEventEdit = true;
    }

    private void OnEventEndDateToggle(bool val)
    {
        _hasEventEndDate = val;
        if (val)
        {
            _editingEvent.EndDate ??= new FuzzyDateDto { Year = _editingEvent.Date.Year };
        }
        else
        {
            _editingEvent.EndDate = null;
        }
    }

    private void OnTagsStringChanged(string? val)
    {
        if (string.IsNullOrWhiteSpace(val))
        {
            _editingEvent.Tags = [];
        }
        else
        {
            _editingEvent.Tags = val.Split(new[] { ',', ' ', '，' }, StringSplitOptions.RemoveEmptyEntries)
                                   .Select(t => t.Trim())
                                   .ToList();
        }
    }

    private async Task SaveEventAsync()
    {
        if (string.IsNullOrWhiteSpace(_editingEvent.Id)) { Toast.Error("卡片 ID 不能为空"); return; }
        var (ok, err) = await Api.SaveEventAsync(_editingEvent, _isNewEvent);
        if (ok)
        {
            Toast.Success("保存成功");
            _showEventEdit = false;
            await LoadEventsAsync();
        }
        else Toast.Error(err ?? "保存失败");
    }

    private async Task DeleteEvent(TimelineEventDto ev)
    {
        var (ok, err) = await Api.DeleteEventAsync(_selectedExhibition.Id, ev.Id);
        if (ok)
        {
            Toast.Success("删除成功");
            await LoadEventsAsync();
        }
        else Toast.Error(err ?? "删除失败");
    }

    private async Task PrevEventPage()
    {
        if (_eventPage > 1)
        {
            _eventPage--;
            await LoadEventsAsync();
        }
    }

    private async Task NextEventPage()
    {
        if (_eventPage < _eventTotalPages)
        {
            _eventPage++;
            await LoadEventsAsync();
        }
    }

    private void PreviewUrl(string? url, string type)
    {
        if (string.IsNullOrEmpty(url)) return;
        _previewUrl = url;
        _previewType = type;
        _showPreviewDialog = true;
    }

    private async Task OnRowDropped(RowDroppedEventArgs<ExhibitionListItem> args)
    {
        var movingItems = args.Data;
        if (movingItems == null || movingItems.Count == 0) return;

        // Syncfusion 拖放后已自动更新 bound 集合 _items 里的元素位置
        // 我们只需根据最新的顺序重新映射 SortOrder 并通知后端
        for (int i = 0; i < _items.Count; i++)
        {
            _items[i].SortOrder = i;
        }

        var orderItems = _items.Select(x => new ExhibitionOrderItem { Id = x.Id, SortOrder = x.SortOrder }).ToList();
        var (ok, err) = await Api.ReorderExhibitionsAsync(new ExhibitionReorderRequest { Items = orderItems });
        if (ok)
        {
            Toast.Success("拖动排序成功");
        }
        else
        {
            Toast.Error(err ?? "排序更新失败");
            await LoadAsync(); // 失败则重新加载并同步状态
        }
    }

    #endregion
}
