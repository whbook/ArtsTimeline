    private async Task ExportSchema(string dataType)
    {
        object? schemaObj = dataType switch
        {
            "period" => new
            {
                entity = "Period",
                name = "分期",
                fields = new[]
                {
                    new { name = "Id", type = "Guid", description = "唯一标识 ID" },
                    new { name = "ExhibitionId", type = "Guid", description = "关联展览 ID" },
                    new { name = "NameCn", type = "String", description = "中文名称" },
                    new { name = "NameEn", type = "String", description = "英文名称" },
                    new { name = "ColorHex", type = "String", description = "文字颜色 Hex 值" },
                    new { name = "ColorBackground", type = "String", description = "背景色 Hex 值" },
                    new { name = "Description", type = "String", description = "详情简介" },
                    new { name = "Start", type = "FuzzyDate", description = "分期开始时间" },
                    new { name = "End", type = "FuzzyDate", description = "分期结束时间" }
                }
            },
            "swimlane" => new
            {
                entity = "Swimlane",
                name = "泳道",
                fields = new[]
                {
                    new { name = "Id", type = "Guid", description = "唯一标识 ID" },
                    new { name = "ExhibitionId", type = "Guid", description = "关联展览 ID" },
                    new { name = "PeriodId", type = "Guid?", description = "关联分期 ID (可空)" },
                    new { name = "NameCn", type = "String", description = "中文名称" },
                    new { name = "NameEn", type = "String", description = "英文名称" },
                    new { name = "Color", type = "String", description = "泳道色 Hex 值" },
                    new { name = "Lane", type = "Int32", description = "轨道序号" },
                    new { name = "DescriptionCn", type = "String", description = "中文简介" },
                    new { name = "DescriptionEn", type = "String", description = "英文简介" },
                    new { name = "Start", type = "FuzzyDate", description = "有效开始时间" },
                    new { name = "End", type = "FuzzyDate", description = "有效结束时间" }
                }
            },
            "event" => new
            {
                entity = "TimelineEvent",
                name = "作品卡片",
                fields = new[]
                {
                    new { name = "Id", type = "Guid", description = "唯一标识 ID" },
                    new { name = "ExhibitionId", type = "Guid", description = "关联展览 ID" },
                    new { name = "PeriodId", type = "Guid?", description = "关联分期 ID (可空)" },
                    new { name = "SwimlaneId", type = "Guid?", description = "关联泳道 ID (可空)" },
                    new { name = "TitleCn", type = "String", description = "中文标题" },
                    new { name = "TitleEn", type = "String", description = "英文标题" },
                    new { name = "CreatorCn", type = "String", description = "创作者(中文)" },
                    new { name = "CreatorEn", type = "String", description = "创作者(英文)" },
                    new { name = "Location", type = "String", description = "藏地/地点" },
                    new { name = "ImageUrl", type = "String", description = "封面图 URL" },
                    new { name = "DetailPageUrl", type = "String", description = "详情页 URL" },
                    new { name = "HighResImageUrl", type = "String", description = "高清原图 URL" },
                    new { name = "DescriptionCn", type = "String", description = "中文详情描述" },
                    new { name = "DescriptionEn", type = "String", description = "英文详情描述" },
                    new { name = "Importance", type = "Int32", description = "重要度/缩放权重 (1-5)" },
                    new { name = "Tags", type = "List<String>", description = "标签列表" },
                    new { name = "Date", type = "FuzzyDate", description = "事件开始时间" },
                    new { name = "EndDate", type = "FuzzyDate?", description = "事件结束时间 (可空)" },
                    new { name = "MetaJson", type = "String (JSON)", description = "柔性自定义元数据 JSON" }
                }
            },
            _ => null
        };

        if (schemaObj == null) return;

        try
        {
            var options = new JsonSerializerOptions
            {
                WriteIndented = true,
                Encoder = JavaScriptEncoder.UnsafeRelaxedJsonEscaping
            };
            var bytes = JsonSerializer.SerializeToUtf8Bytes(schemaObj, options);
            var base64 = Convert.ToBase64String(bytes);
            var finalFileName = $"{dataType}_schema.json";
            await JS.InvokeVoidAsync("downloadFile", finalFileName, "application/json", base64);
            Toast.Success($"{finalFileName} 结构定义导出成功！");
        }
        catch (Exception ex)
        {
            Toast.Error($"结构导出失败: {ex.Message}");
        }
    }

    #endregion
