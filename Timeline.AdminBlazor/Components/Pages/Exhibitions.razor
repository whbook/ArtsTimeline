@page "/exhibitions"
@attribute [Authorize]
@inject AdminApiClient Api
@inject AuthService AuthService
@inject ToastService Toast
@inject IJSRuntime JS
@using Microsoft.AspNetCore.Components.Authorization
@using System.Text.Encodings.Web
@using System.Text.Json
@using Syncfusion.Blazor
@using Syncfusion.Blazor.Buttons
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.Popups
@using Syncfusion.Blazor.Navigations
@using Syncfusion.Blazor.Inputs
@using Syncfusion.Blazor.DropDowns
@using Timeline.AdminBlazor.Models
@using Timeline.AdminBlazor.Components.Shared

<div class="page-header">
    <h2>展览管理</h2>
    <div class="page-header-right">
        <div class="e-input-group filter-search-box">
            <SfTextBox @bind-Value="_keyword" Placeholder="搜索名称、Slug..." ShowClearButton="true" Input="@OnSearchInput" />
            <span class="e-input-group-icon e-icons e-search" @onclick="ExecuteSearch"></span>
        </div>
        <AuthorizeView Roles="super_admin,admin">
            <SfButton Content="从基础定义同步" CssClass="e-small e-outline" IconCss="e-icons e-refresh" @onclick="SyncFromData" Disabled="_syncing" />
            <SfButton Content="一键无损历史导库" IsPrimary="false" CssClass="e-small e-outline" IconCss="e-icons e-circle-add" @onclick="ImportLegacyData" Disabled="_syncing" />
            <SfButton Content="新建展览" IsPrimary="true" CssClass="e-small" IconCss="e-icons e-plus" @onclick="CreateNew" />
        </AuthorizeView>
    </div>
</div>

<SfGrid @ref="_grid" DataSource="@_items" AllowPaging="true" AllowResizing="true" Height="calc(100vh - 220px)" AllowRowDragAndDrop="true" AllowSelection="true">
    <GridPageSettings PageSize="@_pageSize" PageSizes="@_pageSizeOptionsCast" />
    <GridEvents TValue="ExhibitionListItem" RowDropped="OnRowDropped" PageChanged="@OnMainPageChanged" />
    <GridRowDropSettings AllowEmptyAreaDrop="false" />
    <GridSelectionSettings Type="Syncfusion.Blazor.Grids.SelectionType.Single" />
    <GridColumns>
        <GridColumn Field="@nameof(ExhibitionListItem.Id)" IsPrimaryKey="true" Visible="false" />
        <GridColumn Field="@nameof(ExhibitionListItem.SortOrder)" HeaderText="排序" Width="70" TextAlign="TextAlign.Center" />
        <GridColumn HeaderText="主题色" Width="80">
            <Template>
                @{ var c = (ExhibitionListItem)context; }
                <span class="color-swatch" style="background:@c.Color; display:inline-block; width:20px; height:20px; border-radius:4px; border:1px solid #ddd;"></span>
            </Template>
        </GridColumn>
        <GridColumn Field="@nameof(ExhibitionListItem.TitleCn)" HeaderText="中文名" Width="140" />
        <GridColumn Field="@nameof(ExhibitionListItem.TitleEn)" HeaderText="英文名" Width="160" />
        <GridColumn Field="@nameof(ExhibitionListItem.Slug)" HeaderText="Slug" Width="150" />
        <GridColumn Field="@nameof(ExhibitionListItem.Description)" HeaderText="简介" Width="280" ClipMode="ClipMode.EllipsisWithTooltip" />
        <GridColumn Field="@nameof(ExhibitionListItem.PlaybackSpeed)" HeaderText="播放倍速" Width="90" />
        <GridColumn Field="@nameof(ExhibitionListItem.InitialZoom)" HeaderText="初始缩放" Width="90" />
        <GridColumn Field="@nameof(ExhibitionListItem.Chunked)" HeaderText="分块" Width="70" DisplayAsCheckBox="true" />
        <GridColumn Field="@nameof(ExhibitionListItem.IsPublished)" HeaderText="已发布" Width="80" DisplayAsCheckBox="true" />
        <GridColumn HeaderText="操作" Width="220">
            <Template>
                @{ var row = (ExhibitionListItem)context; }
                <SfButton Content="属性" CssClass="e-small e-flat e-primary" @onclick="() => Edit(row.Id)" />
                <SfButton Content="数据编辑" CssClass="e-small e-flat e-success" IconCss="e-icons e-star-filled" @onclick="() => OpenDataManager(row)" />
            </Template>
        </GridColumn>
    </GridColumns>
</SfGrid>

@* --- 弹窗 1：展览参数与基本信息编辑 --- *@
@if (_showDialog)
{
    <SfDialog @bind-Visible="_showDialog" Width="780px" IsModal="true" ShowCloseIcon="true" Header="@(_isNew ? "新建展览" : "编辑展览属性")">
        <DialogTemplates>
            <Content>
                <SfTab>
                    <TabItems>
                        <TabItem>
                            <HeaderTemplate>基本信息</HeaderTemplate>
                            <ContentTemplate>
                                <div class="form-section">
                                    <div class="form-row">
                                        <label>Slug</label>
                                        <SfTextBox @bind-Value="_model.Slug" Enabled="@_isNew" CssClass="e-small" />
                                    </div>
                                    <div class="form-row align-top">
                                        <label>主题色</label>
                                        <HexColorEditor @bind-Value="_model.Color" Placeholder="#2563eb" />
                                    </div>
                                    <div class="form-row">
                                        <label>中文名</label>
                                        <SfTextBox @bind-Value="_model.TitleCn" CssClass="e-small" />
                                    </div>
                                    <div class="form-row">
                                        <label>英文名</label>
                                        <SfTextBox @bind-Value="_model.TitleEn" CssClass="e-small" />
                                    </div>
                                    <div class="form-row align-top">
                                        <label>简介</label>
                                        <SfTextArea @bind-Value="_model.Description" Rows="3" Width="100%" ResizeMode="Resize.Vertical" />
                                    </div>
                                    <div class="form-row">
                                        <label>排序</label>
                                        <SfNumericTextBox @bind-Value="_model.SortOrder" CssClass="e-small" />
                                    </div>
                                    <div class="form-row">
                                        <label>发布</label>
                                        <SfCheckBox Label="已发布" @bind-Checked="_model.IsPublished" />
                                    </div>
                                </div>
                            </ContentTemplate>
                        </TabItem>
                        <TabItem>
                            <HeaderTemplate>运行参数</HeaderTemplate>
                            <ContentTemplate>
                                <div class="form-section">
                                    <div class="form-row">
                                        <label>播放速度倍率</label>
                                        <SfNumericTextBox @bind-Value="_model.PlaybackSpeed" Decimals="2" CssClass="e-small" />
                                    </div>
                                    <div class="form-row">
                                        <label>初始放大倍数</label>
                                        <SfNumericTextBox @bind-Value="_model.InitialZoom" Decimals="2" CssClass="e-small" />
                                    </div>
                                    <div class="form-row">
                                        <label>分块加载</label>
                                        <SfCheckBox Label="启用分块加载" @bind-Checked="_model.Chunked" />
                                    </div>
                                </div>
                            </ContentTemplate>
                        </TabItem>
                        <TabItem>
                            <HeaderTemplate>字段定义 JSON</HeaderTemplate>
                            <ContentTemplate>
                                <div class="form-section">
                                    <div class="form-row align-top">
                                        <label>eventFields</label>
                                        <SfTextArea @bind-Value="_model.EventFieldsJson" Rows="14" Width="100%" ResizeMode="Resize.Vertical" />
                                    </div>
                                </div>
                            </ContentTemplate>
                        </TabItem>
                    </TabItems>
                </SfTab>
            </Content>
        </DialogTemplates>
        <DialogButtons>
            <DialogButton Content="保存" IsPrimary="true" OnClick="@Save" />
            <DialogButton Content="取消" OnClick="@Cancel" />
        </DialogButtons>
    </SfDialog>
}

@* --- 弹窗 2：大型全功能数据编辑面板 --- *@
@if (_showDataManager)
{
    <SfDialog @bind-Visible="_showDataManager" Width="1150px" Height="850px" IsModal="true" ShowCloseIcon="true" CssClass="data-manager-dialog" Header="@($"管理展览具体数据：{_selectedExhibition.TitleCn} ({_selectedExhibition.Slug})")">
        <DialogTemplates>
            <Content>
                <div class="manager-container">
                    <SfTab CssClass="manager-tab" Height="100%">
                        <TabItems>
                            @* 2.1 分期 Tab *@
                            <TabItem>
                                <HeaderTemplate>分期 (Periods)</HeaderTemplate>
                                <ContentTemplate>
                                    <div class="sub-grid-panel">
                                        <div class="grid-actions">
                                            <div style="display: flex; gap: 6px; align-items: center;">
                                                <SfButton Content="新增分期" IsPrimary="true" CssClass="e-small" IconCss="e-icons e-plus" @onclick="CreatePeriod" />
                                                <SfButton Content="导出数据" CssClass="e-small e-outline" IconCss="e-icons e-description" @onclick='() => OpenExportDialog("period")' />
                                                <SfButton Content="导出数据结构" CssClass="e-small e-outline" IconCss="e-icons e-code-view" @onclick='() => ExportSchema("period")' />
                                            </div>
                                            <div style="display: flex; gap: 8px; align-items: center;">
                                                <div class="e-input-group filter-search-box">
                                                    <SfTextBox @bind-Value="_periodKeyword" Placeholder="在当前列表中搜索..." ShowClearButton="true" Input="@OnPeriodSearchInput" />
                                                    <span class="e-input-group-icon e-icons e-search" @onclick="ExecutePeriodSearch"></span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="sub-grid-body">
                                        <SfGrid @ref="_periodGrid" DataSource="@_filteredPeriods" Height="100%" AllowPaging="true" AllowResizing="true">
                                            <GridPageSettings PageSize="@_periodPageSize" PageSizes="@_pageSizeOptionsCast" />
                                            <GridEvents TValue="PeriodDto" PageChanged="@OnPeriodPageChanged" />
                                            <GridColumns>
                                                <GridColumn Field="@nameof(PeriodDto.Id)" HeaderText="ID" Width="120" />
                                                <GridColumn Field="@nameof(PeriodDto.NameCn)" HeaderText="中文名" Width="120" />
                                                <GridColumn Field="@nameof(PeriodDto.NameEn)" HeaderText="英文名" Width="120" />
                                                <GridColumn HeaderText="起止年份" Width="160">
                                                    <Template>
                                                        @{ var p = (PeriodDto)context; }
                                                        <span>@FormatFuzzyDateString(p.Start) ~ @FormatFuzzyDateString(p.End)</span>
                                                    </Template>
                                                </GridColumn>
                                                <GridColumn HeaderText="前景色/背景色" Width="140">
                                                    <Template>
                                                        @{ var p = (PeriodDto)context; }
                                                        <span class="color-swatch-badge" style="color:@p.ColorHex; background:@p.ColorBackground; padding:2px 6px; border-radius:4px; border:1px solid #ccc; font-size:11px;">@p.ColorHex / @p.ColorBackground</span>
                                                    </Template>
                                                </GridColumn>
                                                <GridColumn Field="@nameof(PeriodDto.Description)" HeaderText="简介" Width="200" ClipMode="ClipMode.EllipsisWithTooltip" />
                                                <GridColumn HeaderText="操作" Width="120">
                                                    <Template>
                                                        @{ var p = (PeriodDto)context; }
                                                        <SfButton Content="编辑" CssClass="e-small e-flat e-primary" @onclick="() => EditPeriod(p)" />
                                                        <SfButton Content="删除" CssClass="e-small e-flat e-danger" @onclick="() => DeletePeriod(p)" />
                                                    </Template>
                                                </GridColumn>
                                            </GridColumns>
                                        </SfGrid>
                                        </div>
                                    </div>
                                </ContentTemplate>
                            </TabItem>

                            @* 2.2 泳道 Tab *@
                            <TabItem>
                                <HeaderTemplate>泳道 (Swimlanes)</HeaderTemplate>
                                <ContentTemplate>
                                    <div class="sub-grid-panel">
                                        <div class="grid-actions">
                                            <div style="display: flex; gap: 6px; align-items: center;">
                                                <SfButton Content="新增泳道" IsPrimary="true" CssClass="e-small" IconCss="e-icons e-plus" @onclick="CreateSwimlane" />
                                                <SfButton Content="导出数据" CssClass="e-small e-outline" IconCss="e-icons e-description" @onclick='() => OpenExportDialog("swimlane")' />
                                                <SfButton Content="导出数据结构" CssClass="e-small e-outline" IconCss="e-icons e-code-view" @onclick='() => ExportSchema("swimlane")' />
                                            </div>
                                            <div style="display: flex; gap: 8px; align-items: center;">
                                                <div class="e-input-group filter-search-box">
                                                    <SfTextBox @bind-Value="_swimlaneKeyword" Placeholder="在当前列表中搜索..." ShowClearButton="true" Input="@OnSwimlaneSearchInput" />
                                                    <span class="e-input-group-icon e-icons e-search" @onclick="ExecuteSwimlaneSearch"></span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="sub-grid-body">
                                        <SfGrid @ref="_swimlaneGrid" DataSource="@_filteredSwimlanes" Height="100%" AllowPaging="true" AllowResizing="true">
                                            <GridPageSettings PageSize="@_swimlanePageSize" PageSizes="@_pageSizeOptionsCast" />
                                            <GridEvents TValue="SwimlaneDto" PageChanged="@OnSwimlanePageChanged" />
                                            <GridColumns>
                                                <GridColumn Field="@nameof(SwimlaneDto.Id)" HeaderText="ID" Width="120" />
                                                <GridColumn Field="@nameof(SwimlaneDto.NameCn)" HeaderText="中文名" Width="120" />
                                                <GridColumn Field="@nameof(SwimlaneDto.NameEn)" HeaderText="英文名" Width="120" />
                                                <GridColumn Field="@nameof(SwimlaneDto.PeriodId)" HeaderText="关联分期" Width="120" />
                                                <GridColumn Field="@nameof(SwimlaneDto.Lane)" HeaderText="轨道号" Width="80" TextAlign="TextAlign.Center" />
                                                <GridColumn HeaderText="起止年份" Width="160">
                                                    <Template>
                                                        @{ var s = (SwimlaneDto)context; }
                                                        <span>@FormatFuzzyDateString(s.Start) ~ @FormatFuzzyDateString(s.End)</span>
                                                    </Template>
                                                </GridColumn>
                                                <GridColumn HeaderText="操作" Width="120">
                                                    <Template>
                                                        @{ var s = (SwimlaneDto)context; }
                                                        <SfButton Content="编辑" CssClass="e-small e-flat e-primary" @onclick="() => EditSwimlane(s)" />
                                                        <SfButton Content="删除" CssClass="e-small e-flat e-danger" @onclick="() => DeleteSwimlane(s)" />
                                                    </Template>
                                                </GridColumn>
                                            </GridColumns>
                                        </SfGrid>
                                        </div>
                                    </div>
                                </ContentTemplate>
                            </TabItem>

                            @* 2.3 作品卡片 Tab *@
                            <TabItem>
                                <HeaderTemplate>作品事件 (Events)</HeaderTemplate>
                                <ContentTemplate>
                                    <div class="sub-grid-panel">
                                        <div class="grid-actions filter-actions">
                                            <div class="left-actions" style="display: inline-flex; align-items: center; gap: 6px;">
                                                <SfButton Content="新增作品卡片" IsPrimary="true" CssClass="e-small" IconCss="e-icons e-plus" @onclick="CreateEvent" />
                                                <SfButton Content="导出数据" CssClass="e-small e-outline" IconCss="e-icons e-description" @onclick='() => OpenExportDialog("event")' />
                                                <SfButton Content="导出数据结构" CssClass="e-small e-outline" IconCss="e-icons e-code-view" @onclick='() => ExportSchema("event")' />
                                            </div>
                                            <div class="right-filters" style="display: inline-flex; align-items: center; gap: 8px;">
                                                <div class="e-input-group filter-search-box">
                                                    <SfTextBox Placeholder="搜索标题、创作者..." Value="@_eventKeyword" ShowClearButton="true" Input="@OnEventSearchInput" />
                                                    <span class="e-input-group-icon e-icons e-search" @onclick="ExecuteEventSearch"></span>
                                                </div>
                                                <div class="dropdown-with-copy">
                                                    <SfDropDownList TValue="int?" TItem="ImportanceOption" DataSource="@_importanceOptions" @bind-Value="_eventImportance" Placeholder="筛选重要度" CssClass="e-small filter-dropdown">
                                                        <DropDownListFieldSettings Text="Label" Value="Value" />
                                                        <DropDownListEvents TValue="int?" TItem="ImportanceOption" ValueChange="async () => { _eventPage = 1; await LoadEventsAsync(); }" />
                                                    </SfDropDownList>
                                                    <DropdownCopyButton Options="@_importanceOptions.Select(x => x.Label)" />
                                                </div>
                                            </div>
                                        </div>
                                        <div class="sub-grid-body">
                                        <SfGrid DataSource="@_events" Height="100%" AllowResizing="true">
                                            <GridColumns>
                                                <GridColumn Field="@nameof(TimelineEventDto.Id)" HeaderText="ID" Width="120" />
                                                <GridColumn Field="@nameof(TimelineEventDto.TitleCn)" HeaderText="中文名" Width="150" />
                                                <GridColumn Field="@nameof(TimelineEventDto.CreatorCn)" HeaderText="创作者" Width="100" />
                                                <GridColumn HeaderText="卡片时间" Width="130">
                                                    <Template>
                                                        @{ var ev = (TimelineEventDto)context; }
                                                        <span>@FormatFuzzyDateString(ev.Date)</span>
                                                    </Template>
                                                </GridColumn>
                                                <GridColumn Field="@nameof(TimelineEventDto.Importance)" HeaderText="重要度" Width="80" TextAlign="TextAlign.Center" />
                                                <GridColumn HeaderText="链接" Width="100">
                                                    <Template>
                                                        @{ var ev = (TimelineEventDto)context; }
                                                        <div class="url-badges">
                                                            @if (!string.IsNullOrEmpty(ev.ImageUrl)) { <span class="badge" title="有封面图">图</span> }
                                                            @if (!string.IsNullOrEmpty(ev.DetailPageUrl)) { <span class="badge" title="有详情链接">页</span> }
                                                            @if (!string.IsNullOrEmpty(ev.HighResImageUrl)) { <span class="badge" title="有高清原图">高</span> }
                                                        </div>
                                                    </Template>
                                                </GridColumn>
                                                <GridColumn HeaderText="操作" Width="120">
                                                    <Template>
                                                        @{ var ev = (TimelineEventDto)context; }
                                                        <SfButton Content="编辑" CssClass="e-small e-flat e-primary" @onclick="() => EditEvent(ev)" />
                                                        <SfButton Content="删除" CssClass="e-small e-flat e-danger" @onclick="() => DeleteEvent(ev)" />
                                                    </Template>
                                                </GridColumn>
                                            </GridColumns>
                                        </SfGrid>
                                        </div>
                                        <div class="custom-pager">
                                            <div style="display: flex; gap: 8px; align-items: center;">
                                                <SfButton Content="上一页" Disabled="@(_eventPage <= 1)" @onclick="PrevEventPage" CssClass="e-small" />
                                                <span class="pager-info">第 @_eventPage 页 / 共 @_eventTotalPages 页 (共 @_eventTotalCount 条)</span>
                                                <SfButton Content="下一页" Disabled="@(_eventPage >= _eventTotalPages)" @onclick="NextEventPage" CssClass="e-small" />
                                            </div>
                                            <div style="display: flex; gap: 6px; align-items: center;">
                                                <span style="font-size: 11px; color: var(--app-text-muted);">每页:</span>
                                                <div class="dropdown-with-copy">
                                                    <SfDropDownList TValue="int" TItem="int" DataSource="@_pageSizeOptions" @bind-Value="_eventPageSize" Width="80px" CssClass="e-small">
                                                        <DropDownListEvents TValue="int" TItem="int" ValueChange="@OnEventPageSizeChanged" />
                                                    </SfDropDownList>
                                                    <DropdownCopyButton Options="@_pageSizeOptions.Select(x => x.ToString())" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </ContentTemplate>
                            </TabItem>
                        </TabItems>
                    </SfTab>
                </div>
            </Content>
        </DialogTemplates>
        <DialogButtons>
            <DialogButton Content="关闭面板" OnClick="() => _showDataManager = false" />
        </DialogButtons>
    </SfDialog>
}

@* --- 弹窗 3：编辑分期 (Period) --- *@
@if (_showPeriodEdit)
{
    <SfDialog @bind-Visible="_showPeriodEdit" Width="680px" IsModal="true" ShowCloseIcon="true" Header="@(_isNewPeriod ? "新建分期" : "编辑分期")">
        <DialogTemplates>
            <Content>
                <div class="form-section">
                    <div class="form-row">
                        <label>中文名称</label>
                        <SfTextBox @bind-Value="_editingPeriod.NameCn" CssClass="e-small" />
                    </div>
                    <div class="form-row">
                        <label>英文名称</label>
                        <SfTextBox @bind-Value="_editingPeriod.NameEn" CssClass="e-small" />
                    </div>
                    <div class="form-row align-top">
                        <label>文字颜色 (Hex)</label>
                        <HexColorEditor @bind-Value="_editingPeriod.ColorHex" Placeholder="#111827" />
                    </div>
                    <div class="form-row align-top">
                        <label>背景颜色 (Hex)</label>
                        <HexColorEditor @bind-Value="_editingPeriod.ColorBackground" Placeholder="#f3f4f6" />
                    </div>
                    <div class="form-row align-top">
                        <label aria-hidden="true"></label>
                        <TextBackgroundColorPreview TextColor="@_editingPeriod.ColorHex"
                                                    BackgroundColor="@_editingPeriod.ColorBackground" />
                    </div>
                    <div class="form-row align-top">
                        <label>分期详情</label>
                        <SfTextArea @bind-Value="_editingPeriod.Description" Rows="3" Width="100%" ResizeMode="Resize.Vertical" />
                    </div>

                    <FuzzyDateEditor @bind-Value="_editingPeriod.Start" Label="开始时间 (Start Date)" />
                    <FuzzyDateEditor @bind-Value="_editingPeriod.End" Label="结束时间 (End Date)" />
                </div>
            </Content>
        </DialogTemplates>
        <DialogButtons>
            <DialogButton Content="保存" IsPrimary="true" OnClick="SavePeriodAsync" />
            <DialogButton Content="取消" OnClick="() => _showPeriodEdit = false" />
        </DialogButtons>
    </SfDialog>
}

@* --- 弹窗 4：编辑泳道 (Swimlane) --- *@
@if (_showSwimlaneEdit)
{
    <SfDialog @bind-Visible="_showSwimlaneEdit" Width="680px" IsModal="true" ShowCloseIcon="true" Header="@(_isNewSwimlane ? "新建泳道" : "编辑泳道")">
        <DialogTemplates>
            <Content>
                <div class="form-section">
                    <div class="form-row">
                        <label>所属分期</label>
                        <div class="dropdown-with-copy">
                            <SfDropDownList TValue="Guid?" TItem="PeriodDto" DataSource="@_periods" @bind-Value="_editingSwimlane.PeriodId" Placeholder="选择关联分期" CssClass="e-small">
                                <DropDownListFieldSettings Text="NameCn" Value="Id" />
                            </SfDropDownList>
                            <DropdownCopyButton Options="@_periods.Select(x => x.NameCn)" />
                        </div>
                    </div>
                    <div class="form-row">
                        <label>中文名称</label>
                        <SfTextBox @bind-Value="_editingSwimlane.NameCn" CssClass="e-small" />
                    </div>
                    <div class="form-row">
                        <label>英文名称</label>
                        <SfTextBox @bind-Value="_editingSwimlane.NameEn" CssClass="e-small" />
                    </div>
                    <div class="form-row align-top">
                        <label>泳道颜色 (Hex)</label>
                        <HexColorEditor @bind-Value="_editingSwimlane.Color" Placeholder="#2563eb" />
                    </div>
                    <div class="form-row">
                        <label>泳道轨道排布序号 (Lane)</label>
                        <SfNumericTextBox @bind-Value="_editingSwimlane.Lane" Format="N0" ShowSpinButton="true" CssClass="e-small" />
                    </div>
                    <div class="form-row align-top">
                        <label>泳道中文简介</label>
                        <SfTextArea @bind-Value="_editingSwimlane.DescriptionCn" Rows="3" Width="100%" ResizeMode="Resize.Vertical" />
                    </div>
                    <div class="form-row align-top">
                        <label>泳道英文简介</label>
                        <SfTextArea @bind-Value="_editingSwimlane.DescriptionEn" Rows="3" Width="100%" ResizeMode="Resize.Vertical" />
                    </div>

                    <FuzzyDateEditor @bind-Value="_editingSwimlane.Start" Label="泳道有效开始时间" />
                    <FuzzyDateEditor @bind-Value="_editingSwimlane.End" Label="泳道有效结束时间" />
                </div>
            </Content>
        </DialogTemplates>
        <DialogButtons>
            <DialogButton Content="保存" IsPrimary="true" OnClick="SaveSwimlaneAsync" />
            <DialogButton Content="取消" OnClick="() => _showSwimlaneEdit = false" />
        </DialogButtons>
    </SfDialog>
}

@* --- 弹窗 5：编辑作品事件 (Event) --- *@
@if (_showEventEdit)
{
    <SfDialog @bind-Visible="_showEventEdit" Width="820px" Height="780px" IsModal="true" ShowCloseIcon="true" Header="@(_isNewEvent ? "新建作品卡片" : "编辑作品卡片")">
        <DialogTemplates>
            <Content>
                <div class="form-scroll-container" style="max-height: 640px; overflow-y: auto; padding-right: 10px;">
                    <div class="form-section">
                        <div class="form-row-grid">
                            <div class="form-row">
                                <label>所属分期</label>
                                <div class="dropdown-with-copy">
                                    <SfDropDownList TValue="Guid?" TItem="PeriodDto" DataSource="@_periods" @bind-Value="_editingEvent.PeriodId" Placeholder="选择分期 (可空)" CssClass="e-small">
                                        <DropDownListFieldSettings Text="NameCn" Value="Id" />
                                    </SfDropDownList>
                                    <DropdownCopyButton Options="@_periods.Select(x => x.NameCn)" />
                                </div>
                            </div>
                            <div class="form-row">
                                <label>所属泳道</label>
                                <div class="dropdown-with-copy">
                                    <SfDropDownList TValue="Guid?" TItem="SwimlaneDto" DataSource="@_swimlanes" @bind-Value="_editingEvent.SwimlaneId" Placeholder="选择泳道 (可空)" CssClass="e-small">
                                        <DropDownListFieldSettings Text="NameCn" Value="Id" />
                                    </SfDropDownList>
                                    <DropdownCopyButton Options="@_swimlanes.Select(x => x.NameCn)" />
                                </div>
                            </div>
                        </div>
                        <div class="form-row">
                            <label>中文标题</label>
                            <SfTextBox @bind-Value="_editingEvent.TitleCn" CssClass="e-small" />
                        </div>
                        <div class="form-row">
                            <label>英文标题</label>
                            <SfTextBox @bind-Value="_editingEvent.TitleEn" CssClass="e-small" />
                        </div>
                        <div class="form-row-grid">
                            <div class="form-row">
                                <label>创作者 (中文)</label>
                                <SfTextBox @bind-Value="_editingEvent.CreatorCn" CssClass="e-small" />
                            </div>
                            <div class="form-row">
                                <label>创作者 (英文)</label>
                                <SfTextBox @bind-Value="_editingEvent.CreatorEn" CssClass="e-small" />
                            </div>
                        </div>
                        <div class="form-row">
                            <label>收藏现藏地 / 地点</label>
                            <SfTextBox @bind-Value="_editingEvent.Location" CssClass="e-small" />
                        </div>
                        <div class="form-row-grid">
                            <div class="form-row">
                                <label>缩放显示权重重要度 (1-最高，5-最低)</label>
                                <SfNumericTextBox @bind-Value="_editingEvent.Importance" Min="1" Max="5" Format="N0" ShowSpinButton="true" CssClass="e-small" />
                            </div>
                            <div class="form-row">
                                <label>标签 (逗号或空格分隔)</label>
                                <SfTextBox Value="@string.Join(", ", _editingEvent.Tags)" ValueChanged="OnTagsStringChanged" Placeholder="输入标签..." CssClass="e-small" />
                            </div>
                        </div>

                        @* 核心新增：三类 URL 属性输入 + 录入校验与预览按钮 *@
                        <div class="url-input-section">
                            <h5 class="url-title">多媒体与外部资源链接</h5>
                            <div class="form-row url-row">
                                <label>封面图像 URL</label>
                                <div class="url-control-group">
                                    <SfTextBox @bind-Value="_editingEvent.ImageUrl" Placeholder="http:// 或 https:// 格式" CssClass="e-small" />
                                    <InputFile id="event-image-upload" OnChange="UploadEventImage" style="display:none;" accept="image/*" />
                                    <label for="event-image-upload" class="e-btn e-small e-success e-outline @(_uploadingImage ? "e-disabled" : "")" style="cursor:pointer; margin:0; display:inline-flex; align-items:center; height: 28px; line-height: 28px; padding: 0 10px;">
                                        @if (_uploadingImage)
                                        {
                                            <span class="e-icons e-refresh" style="margin-right:4px; animation: spin 1s linear infinite;"></span><span>上传中...</span>
                                        }
                                        else
                                        {
                                            <span class="e-icons e-image" style="margin-right:4px;"></span><span>本地上传</span>
                                        }
                                    </label>
                                    <SfButton Content="预览" CssClass="e-small e-outline" OnClick="@(() => PreviewUrl(_editingEvent.ImageUrl, "image"))" Disabled="@string.IsNullOrEmpty(_editingEvent.ImageUrl)" />
                                </div>
                            </div>
                            <div class="form-row url-row">
                                <label>详情页 URL</label>
                                <div class="url-control-group">
                                    <SfTextBox @bind-Value="_editingEvent.DetailPageUrl" Placeholder="外部详情、介绍网页链接" CssClass="e-small" />
                                    <SfButton Content="跳转" CssClass="e-small e-outline" OnClick="@(() => PreviewUrl(_editingEvent.DetailPageUrl, "web"))" Disabled="@string.IsNullOrEmpty(_editingEvent.DetailPageUrl)" />
                                </div>
                            </div>
                            <div class="form-row url-row">
                                <label>高清原图 URL</label>
                                <div class="url-control-group">
                                    <SfTextBox @bind-Value="_editingEvent.HighResImageUrl" Placeholder="超高分辨率无损大图链接" CssClass="e-small" />
                                    <InputFile id="event-highres-upload" OnChange="UploadHighResImage" style="display:none;" accept="image/*" />
                                    <label for="event-highres-upload" class="e-btn e-small e-success e-outline @(_uploadingHighRes ? "e-disabled" : "")" style="cursor:pointer; margin:0; display:inline-flex; align-items:center; height: 28px; line-height: 28px; padding: 0 10px;">
                                        @if (_uploadingHighRes)
                                        {
                                            <span class="e-icons e-refresh" style="margin-right:4px; animation: spin 1s linear infinite;"></span><span>上传中...</span>
                                        }
                                        else
                                        {
                                            <span class="e-icons e-image" style="margin-right:4px;"></span><span>本地上传</span>
                                        }
                                    </label>
                                    <SfButton Content="预览" CssClass="e-small e-outline" OnClick="@(() => PreviewUrl(_editingEvent.HighResImageUrl, "image"))" Disabled="@string.IsNullOrEmpty(_editingEvent.HighResImageUrl)" />
                                </div>
                            </div>
                        </div>

                        <div class="form-row align-top">
                            <label>中文详情描述</label>
                            <SfTextArea @bind-Value="_editingEvent.DescriptionCn" Rows="3" Width="100%" ResizeMode="Resize.Vertical" />
                        </div>
                        <div class="form-row align-top">
                            <label>英文详情描述</label>
                            <SfTextArea @bind-Value="_editingEvent.DescriptionEn" Rows="3" Width="100%" ResizeMode="Resize.Vertical" />
                        </div>

                        <FuzzyDateEditor @bind-Value="_editingEvent.Date" Label="卡片事件时间 (必填)" />
                        
                        <div class="form-row checkbox-row">
                            <SfCheckBox TChecked="bool" Label="启用结束时间" Checked="@_hasEventEndDate" CheckedChanged="@OnEventEndDateToggle" />
                        </div>
                        @if (_hasEventEndDate)
                        {
                            <FuzzyDateEditor @bind-Value="_editingEvent.EndDate" Label="卡片事件结束时间" />
                        }

                        @* 柔性元数据动态表单编辑器 *@
                        <EventMetaEditor EventFieldsJson="@_selectedExhibition.EventFieldsJson" @bind-MetaJson="_editingEvent.MetaJson" />
                    </div>
                </div>
            </Content>
        </DialogTemplates>
        <DialogButtons>
            <DialogButton Content="保存" IsPrimary="true" OnClick="SaveEventAsync" />
            <DialogButton Content="取消" OnClick="() => _showEventEdit = false" />
        </DialogButtons>
    </SfDialog>
}

@* --- 弹窗 7：导出配置窗口 --- *@
<ExportConfigDialog @bind-Visible="_showExportDialog"
                    ExhibitionId="_selectedExhibition.Id"
                    DataType="@_exportDataType"
                    DataList="@_exportDataList" />

@* --- 弹窗 6：URL 预览窗口 --- *@
@if (_showPreviewDialog)
{
    <SfDialog @bind-Visible="_showPreviewDialog" Width="650px" IsModal="true" ShowCloseIcon="true" Header="资源预览">
        <DialogTemplates>
            <Content>
                <div class="preview-dialog-body" style="text-align:center; padding:15px 0;">
                    @if (_previewType == "image")
                    {
                        <img src="@_previewUrl" alt="预览图" style="max-width:100%; max-height:450px; border-radius:4px; box-shadow:0 2px 8px rgba(0,0,0,0.15);" />
                    }
                    else
                    {
                        <p class="preview-text">由于同源或安全机制限制，部分网页不便在内嵌框架中呈现。建议点击下方按钮：</p>
                        <a href="@_previewUrl" target="_blank" class="e-btn e-success" style="text-decoration:none; margin-top:10px;">在新标签页中访问该链接</a>
                    }
                    <div style="margin-top:15px; font-size:11px; color:var(--app-text-muted, #777); word-break:break-all;">
                        资源地址：@_previewUrl
                    </div>
                </div>
            </Content>
        </DialogTemplates>
        <DialogButtons>
            <DialogButton Content="关闭" OnClick="() => _showPreviewDialog = false" />
        </DialogButtons>
    </SfDialog>
}

<style>
    .color-swatch-badge {
        font-family: monospace;
    }

    .grid-actions {
        padding-top: 10px;
        margin-bottom: 12px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .filter-actions {
        display: flex;
        width: 100%;
    }
    .right-filters {
        display: flex;
        gap: 12px;
        align-items: center;
    }
    .filter-box {
        width: 220px;
    }
    .filter-dropdown {
        width: 150px;
    }
    .custom-pager {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 15px;
        margin-top: 0;
        border-top: 1px solid var(--app-border, #e5e7eb);
        padding: 10px 10px 0;
    }
    .pager-info {
        font-size: 13px;
        color: var(--app-text-muted, #4b5563);
    }
    .form-row-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
    }
    .checkbox-row {
        margin: 10px 0;
    }
    .url-input-section {
        margin-top: 15px;
        margin-bottom: 15px;
        border: 1px solid var(--app-border, #e5e7eb);
        border-radius: 6px;
        padding: 12px;
        background: var(--app-bg, #fff);
    }
    .url-title {
        font-weight: bold;
        font-size: 13px;
        margin-top: 0;
        margin-bottom: 10px;
        color: var(--app-primary, #2563eb);
    }
    .url-row {
        margin-bottom: 8px;
    }
    .url-row:last-child {
        margin-bottom: 0;
    }
    .url-control-group {
        display: flex;
        gap: 8px;
        align-items: center;
    }
    .url-control-group .e-textbox-container {
        flex: 1;
    }
    .url-badges {
        display: flex;
        gap: 4px;
    }
    .url-badges .badge {
        display: inline-block;
        font-size: 10px;
        background: var(--app-bg-subtle, #f3f4f6);
        color: var(--app-text, #374151);
        border: 1px solid var(--app-border, #d1d5db);
        border-radius: 3px;
        padding: 1px 4px;
        font-weight: bold;
    }
    
    /* 拖拽手柄样式 - 强行设置拖拽手柄列和 col 的宽度，避免 Syncfusion 首次渲染计算为 1px */
    .e-grid colgroup col.e-rowdragdrop,
    .e-grid colgroup col:first-child {
        width: 38px !important;
    }
    .e-grid .e-dragheader,
    .e-grid .e-rowdragheader {
        width: 38px !important;
        min-width: 38px !important;
    }
    .e-grid .e-rowdragdrop {
        width: 38px !important;
        min-width: 38px !important;
        cursor: move;
        cursor: grab;
        text-align: center !important;
        display: table-cell !important;
    }
    .e-grid .e-rowdragdrop:active {
        cursor: grabbing;
    }
    .e-grid .e-rowdragdrop .e-dragicon {
        font-family: 'e-icons' !important;
        display: inline-block !important;
        font-size: 14px !important;
        color: var(--app-text-muted, #64748b) !important;
    }
</style>

@code {
    private SfGrid<ExhibitionListItem> _grid = null!;
    private SfGrid<PeriodDto> _periodGrid = null!;
    private SfGrid<SwimlaneDto> _swimlaneGrid = null!;

    private List<ExhibitionListItem> _items = [];
    private bool _showDialog;
    private bool _isNew;
    private bool _syncing;
    private ExhibitionModel _model = new();
    private bool _initialLoadDone;

    // 数据编辑器状态
    private bool _showDataManager;
    private ExhibitionListItem _selectedExhibition = new();
    private List<PeriodDto> _periods = [];
    private List<PeriodDto> _filteredPeriods = [];
    private List<SwimlaneDto> _swimlanes = [];
    private List<SwimlaneDto> _filteredSwimlanes = [];
    private List<TimelineEventDto> _events = [];

    // 分期/泳道/事件编辑窗体
    private bool _showPeriodEdit;
    private bool _isNewPeriod;
    private PeriodDto _editingPeriod = new();

    private bool _showSwimlaneEdit;
    private bool _isNewSwimlane;
    private SwimlaneDto _editingSwimlane = new();

    private bool _showEventEdit;
    private bool _isNewEvent;
    private TimelineEventDto _editingEvent = new();
    private bool _hasEventEndDate;
    private bool _uploadingImage;
    private bool _uploadingHighRes;
    private bool _showExportDialog;
    private string _exportDataType = string.Empty;
    private object? _exportDataList;

    // 预览窗体
    private bool _showPreviewDialog;
    private string _previewUrl = string.Empty;
    private string _previewType = "web"; // web | image

    // 搜索与分页
    private string? _keyword;
    private int _pageSize = 100;
    private readonly List<int> _pageSizeOptions = [100, 500, 1000, 5000, 10000];
    private readonly object[] _pageSizeOptionsCast = [100, 500, 1000, 5000, 10000];

    private string? _periodKeyword;
    private int _periodPageSize = 100;

    private string? _swimlaneKeyword;
    private int _swimlanePageSize = 100;

    private int _eventPage = 1;
    private int _eventPageSize = 100;
    private int _eventTotalCount;
    private int _eventTotalPages => (int)Math.Ceiling((double)_eventTotalCount / _eventPageSize);
    private string? _eventKeyword;
    private int? _eventImportance;

    private class ImportanceOption
    {
        public int? Value { get; set; }
        public string Label { get; set; } = string.Empty;
    }

    private readonly List<ImportanceOption> _importanceOptions = new()
    {
        new ImportanceOption { Value = null, Label = "全部重要度" },
        new ImportanceOption { Value = 1, Label = "1 - 最高" },
        new ImportanceOption { Value = 2, Label = "2 - 较高" },
        new ImportanceOption { Value = 3, Label = "3 - 普通" },
        new ImportanceOption { Value = 4, Label = "4 - 较低" },
        new ImportanceOption { Value = 5, Label = "5 - 最低" }
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _initialLoadDone) return;
        _initialLoadDone = true;
        await AuthService.InitializeAsync();
        await LoadAsync();
        StateHasChanged();
    }

    private async Task LoadAsync()
    {
        var (items, err) = await Api.GetExhibitionsWithErrorAsync();
        if (err is not null)
        {
            Toast.Error(err);
            _items = [];
            return;
        }

        var list = items ?? [];
        if (!string.IsNullOrWhiteSpace(_keyword))
        {
            var k = _keyword.Trim().ToLower();
            list = list.Where(e => e.TitleCn.ToLower().Contains(k) || e.TitleEn.ToLower().Contains(k) || e.Slug.ToLower().Contains(k)).ToList();
        }

        _items = list;
    }

    private async Task OnSearchInput(InputEventArgs e)
    {
        _keyword = e.Value;
        await ExecuteSearch();
    }

    private async Task ExecuteSearch()
    {
        if (_grid is not null)
        {
            await _grid.GoToPageAsync(1);
        }
        await LoadAsync();
    }

    private async Task OnMainPageChanged(GridPageChangedEventArgs args)
    {
        if (args.CurrentPageSize != _pageSize)
        {
            _pageSize = args.CurrentPageSize;
            if (_grid is not null)
            {
                await _grid.GoToPageAsync(1);
            }
            await LoadAsync();
        }
    }

    private async Task SyncFromData()
    {
        _syncing = true;
        var (ok, count, message, err) = await Api.SyncExhibitionsFromDataAsync();
        _syncing = false;
        if (ok)
        {
            Toast.Success(message ?? $"已同步 {count} 个展览");
            await LoadAsync();
        }
        else Toast.Error(err ?? "同步失败");
    }

    private async Task ImportLegacyData()
    {
        _syncing = true;
        var (ok, err, msg) = await Api.ImportLegacyJsonAsync();
        _syncing = false;
        if (ok)
        {
            Toast.Success(msg ?? "历史展览数据一键无损导入成功！");
            await LoadAsync();
        }
        else
        {
            Toast.Error(err ?? "导入失败");
        }
    }

    private void CreateNew()
    {
        _isNew = true;
        _model = new ExhibitionModel();
        _showDialog = true;
    }

    private async Task Edit(Guid id)
    {
        var ex = await Api.GetExhibitionAsync(id);
        if (ex is null) { Toast.Error("加载失败"); return; }
        _model = ex;
        _isNew = false;
        _showDialog = true;
    }

    private async Task Save()
    {
        var (ok, err) = await Api.SaveExhibitionAsync(_model, _isNew);
        if (ok) { Toast.Success("保存成功"); _showDialog = false; await LoadAsync(); }
        else Toast.Error(err ?? "保存失败");
    }

    private Task Cancel() { _showDialog = false; return Task.CompletedTask; }

    #region 子数据管理器逻辑

    private async Task OpenDataManager(ExhibitionListItem ex)
    {
        _selectedExhibition = ex;
        _eventPage = 1;
        _eventKeyword = null;
        _eventImportance = null;
        _periodKeyword = null;
        _swimlaneKeyword = null;

        // 加载当前展览关联的 Periods, Swimlanes, Events
        await LoadPeriodsAsync();
        await LoadSwimlanesAsync();
        await LoadEventsAsync();

        _showDataManager = true;
    }

    private async Task LoadPeriodsAsync()
    {
        _periods = await Api.GetPeriodsAsync(_selectedExhibition.Id) ?? [];
        ApplyPeriodFilter();
    }

    private async Task LoadSwimlanesAsync()
    {
        _swimlanes = await Api.GetSwimlanesAsync(_selectedExhibition.Id) ?? [];
        ApplySwimlaneFilter();
    }

    private async Task LoadEventsAsync()
    {
        var pageResult = await Api.GetEventsAsync(_selectedExhibition.Id, _eventPage, _eventPageSize, _eventKeyword, _eventImportance);
        if (pageResult is not null)
        {
            _events = pageResult.Items;
            _eventTotalCount = pageResult.TotalCount;
        }
        else
        {
            _events = [];
            _eventTotalCount = 0;
        }
    }

    private void ApplyPeriodFilter()
    {
        if (string.IsNullOrWhiteSpace(_periodKeyword))
        {
            _filteredPeriods = _periods;
        }
        else
        {
            var k = _periodKeyword.Trim().ToLower();
            _filteredPeriods = _periods.Where(p => p.NameCn.ToLower().Contains(k) || p.NameEn.ToLower().Contains(k) || p.Id.ToString().Contains(k)).ToList();
        }
    }

    private void ApplySwimlaneFilter()
    {
        if (string.IsNullOrWhiteSpace(_swimlaneKeyword))
        {
            _filteredSwimlanes = _swimlanes;
        }
        else
        {
            var k = _swimlaneKeyword.Trim().ToLower();
            _filteredSwimlanes = _swimlanes.Where(s => s.NameCn.ToLower().Contains(k) || s.NameEn.ToLower().Contains(k) || s.Id.ToString().Contains(k)).ToList();
        }
    }

    private async Task OnPeriodSearchInput(InputEventArgs e)
    {
        _periodKeyword = e.Value;
        await ExecutePeriodSearch();
    }

    private async Task ExecutePeriodSearch()
    {
        ApplyPeriodFilter();
        if (_periodGrid is not null)
        {
            await _periodGrid.GoToPageAsync(1);
        }
        StateHasChanged();
    }

    private async Task OnPeriodPageChanged(GridPageChangedEventArgs args)
    {
        if (args.CurrentPageSize != _periodPageSize)
        {
            _periodPageSize = args.CurrentPageSize;
            if (_periodGrid is not null)
            {
                await _periodGrid.GoToPageAsync(1);
            }
        }
    }

    private async Task OnSwimlaneSearchInput(InputEventArgs e)
    {
        _swimlaneKeyword = e.Value;
        await ExecuteSwimlaneSearch();
    }

    private async Task ExecuteSwimlaneSearch()
    {
        ApplySwimlaneFilter();
        if (_swimlaneGrid is not null)
        {
            await _swimlaneGrid.GoToPageAsync(1);
        }
        StateHasChanged();
    }

    private async Task OnSwimlanePageChanged(GridPageChangedEventArgs args)
    {
        if (args.CurrentPageSize != _swimlanePageSize)
        {
            _swimlanePageSize = args.CurrentPageSize;
            if (_swimlaneGrid is not null)
            {
                await _swimlaneGrid.GoToPageAsync(1);
            }
        }
    }

    private async Task OnEventSearchInput(InputEventArgs e)
    {
        _eventKeyword = e.Value;
        await ExecuteEventSearch();
    }

    private async Task ExecuteEventSearch()
    {
        _eventPage = 1;
        await LoadEventsAsync();
    }

    private async Task OnEventPageSizeChanged(ChangeEventArgs<int, int> args)
    {
        _eventPageSize = args.Value;
        _eventPage = 1;
        await LoadEventsAsync();
    }

    private string FormatFuzzyDateString(FuzzyDateDto fd)
    {
        if (fd is null) return string.Empty;
        var yStr = fd.Year < 0 ? $"公元前 {Math.Abs(fd.Year)}" : $"{fd.Year}";
        var suf = fd.Accuracy switch
        {
            "approximate" => " 约",
            "not_before" => " 不早于",
            "not_after" => " 不晚于",
            "either_or" => fd.OrYear.HasValue ? $" 或 {(fd.OrYear.Value < 0 ? $"公元前 {Math.Abs(fd.OrYear.Value)}" : $"{fd.OrYear.Value}")}" : "",
            _ => ""
        };
        return $"{yStr}{suf}年";
    }

    #endregion

    #region Periods CRUD

    private void CreatePeriod()
    {
        _isNewPeriod = true;
        _editingPeriod = new PeriodDto
        {
            Id = Guid.Empty,
            ExhibitionId = _selectedExhibition.Id,
            ColorHex = "#111827",
            ColorBackground = "#f3f4f6",
            Start = new FuzzyDateDto { Year = 1900 },
            End = new FuzzyDateDto { Year = 2000 }
        };
        _showPeriodEdit = true;
    }

    private void EditPeriod(PeriodDto p)
    {
        _isNewPeriod = false;
        _editingPeriod = p;
        _showPeriodEdit = true;
    }

    private async Task SavePeriodAsync()
    {
        var (ok, err) = await Api.SavePeriodAsync(_editingPeriod, _isNewPeriod);
        if (ok)
        {
            Toast.Success("保存成功");
            _showPeriodEdit = false;
            await LoadPeriodsAsync();
        }
        else Toast.Error(err ?? "保存失败");
    }

    private async Task DeletePeriod(PeriodDto p)
    {
        var (ok, err) = await Api.DeletePeriodAsync(_selectedExhibition.Id, p.Id);
        if (ok)
        {
