@page "/audit-logs"
@attribute [Authorize]
@inject AdminApiClient Api
@inject AuthService AuthService

<div class="page-header">
    <h2>操作日志</h2>
    <div class="page-header-right">
        <div class="e-input-group filter-search-box" style="width: 240px; border-radius: 4px; display: inline-flex; align-items: center; margin-right: 8px;">
            <SfTextBox @bind-Value="_keyword" Placeholder="搜索日志..." ShowClearButton="true" Input="@OnSearchInput" />
            <span class="e-input-group-icon e-icons e-search" @onclick="ExecuteSearch" style="cursor: pointer; padding: 0 8px;"></span>
        </div>
    </div>
</div>

<SfGrid @ref="_gridRef" DataSource="@_items" AllowPaging="true" AllowResizing="true" Height="calc(100vh - 180px)">
    <GridPageSettings PageSize="@_pageSize" PageSizes="@_pageSizeOptionsCast" />
    <GridEvents TValue="AuditLogListItem" PageChanged="@OnPageChanged" />
    <GridColumns>
        <GridColumn Field="@nameof(AuditLogListItem.CreatedAt)" HeaderText="时间" Format="yyyy-MM-dd HH:mm:ss" Width="160" />
        <GridColumn Field="@nameof(AuditLogListItem.AdminUsername)" HeaderText="操作人" Width="100" />
        <GridColumn Field="@nameof(AuditLogListItem.Action)" HeaderText="动作" Width="80" />
        <GridColumn Field="@nameof(AuditLogListItem.EntityType)" HeaderText="对象类型" Width="120" />
        <GridColumn Field="@nameof(AuditLogListItem.EntityLabel)" HeaderText="对象" Width="140" />
        <GridColumn Field="@nameof(AuditLogListItem.Summary)" HeaderText="摘要" Width="260" />
        <GridColumn Field="@nameof(AuditLogListItem.IpAddress)" HeaderText="IP" Width="120" />
    </GridColumns>
</SfGrid>

@code {
    private SfGrid<AuditLogListItem> _gridRef = null!;
    private List<AuditLogListItem> _items = [];
    private string? _keyword;

    private int _pageSize = 100;
    private readonly object[] _pageSizeOptionsCast = [100, 500, 1000, 5000, 10000];

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        var result = await Api.GetAuditLogsAsync(page: 1, pageSize: _pageSize, keyword: _keyword);
        _items = result?.Items ?? [];
    }

    private async Task OnSearchInput(InputEventArgs e)
    {
        _keyword = e.Value;
        await ExecuteSearch();
    }

    private async Task ExecuteSearch()
    {
        if (_gridRef is not null)
        {
            await _gridRef.GoToPageAsync(1);
        }
        await LoadAsync();
    }

    private async Task OnPageChanged(GridPageChangedEventArgs args)
    {
        if (args.CurrentPageSize != _pageSize)
        {
            _pageSize = args.CurrentPageSize;
            if (_gridRef is not null)
            {
                await _gridRef.GoToPageAsync(1);
            }
            await LoadAsync();
        }
    }
}
